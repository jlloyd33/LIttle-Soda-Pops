#include <iostream>
#include <vector>
#include <string>
#include <memory>
#include <iomanip>

using namespace std;

enum class PaymentType { Credit = 1, Debit = 2 };

// ==========================================
// 1. INVENTORY COMPONENT
// ==========================================
class InventoryItem 
{
private:
    string itemId;
    int currentStock;
    int minimumLevel;

public:
    InventoryItem(string id, int stock, int minLevel)
        : itemId(id), currentStock(stock), minimumLevel(minLevel) {}

    string getItemId() const { return itemId; }
    int getCurrentStock() const { return currentStock; }
    bool isLow() const { return currentStock <= minimumLevel; }

    bool deductStock(int amount) 
    {
        if (currentStock >= amount) 
        {
            currentStock -= amount;
            return true;
        }
        cout << "[Inventory Warning]: Out of stock for item " << itemId << "!" << endl;
        return false;
    }
};

// ==========================================
// 2. PAYMENT METHODS HIERARCHY
// ==========================================
class PaymentMethod 
{
protected:
    string paymentId;
    double amount;

public:
    PaymentMethod(string id, double amt) : paymentId(id), amount(amt) {}
    virtual ~PaymentMethod() = default;

    virtual bool authorize() = 0;
    double getAmount() const { return amount; }
};

class Credit : public PaymentMethod 
{
private:
    string zipCode;

public:
    Credit(string id, double amt, const string& zip)
        : PaymentMethod(id, amt), zipCode(zip) {}

    bool authorize() override 
    {
        cout << "[Processing Credit...] Authorizing ZIP " << zipCode << " for $" << amount << endl;
        return true;
    }
};

class Debit : public PaymentMethod 
{
private:
    string pinNumber;

public:
    Debit(string id, double amt, const string& pin)
        : PaymentMethod(id, amt), pinNumber(pin) {}

    bool authorize() override 
    {
        cout << "[Processing Debit...] Verifying PIN " << pinNumber << " for $" << amount << endl;
        return true;
    }
};

// ==========================================
// 3. ORDER COMPONENT
// ==========================================
class Order 
{
private:
    int orderId;
    bool isMixed;
    vector<string> flavorChoice;

public:
    Order(int id) : orderId(id), isMixed(false) {}

    void addFlavor(const string& flavor)
    {
        flavorChoice.push_back(flavor);
        if (flavorChoice.size() > 1) 
        {
            isMixed = true;
        }
    }

    bool finalizeOrder(InventoryItem& syrupInventory)
    {
        if (syrupInventory.getCurrentStock() < static_cast<int>(flavorChoice.size())) 
        {
            cout << "[SFS Display] Dispatch Error: System has insufficient syrup to fulfill this combo." << endl;
            return false;
        }

        cout << "[Order] Dispensing your drink combo: ";
        for (const auto& flavor : flavorChoice) 
        {
            cout << flavor << " ";
            syrupInventory.deductStock(1);
        }
        cout << "\n[SFS Display] Your Soda is ready. Thank you!\n" << endl;
        return true;
    }
};

// ==========================================
// 4. TRANSACTION COMPONENT
// ==========================================
class Transaction
{
private:
    int transactionId;
    double totalPrice;
    unique_ptr<PaymentMethod> payment;

public:
    Transaction(int id) : transactionId(id), totalPrice(2.00) {}

    double getTotalPrice() const { return totalPrice; }

    bool processPayment(unique_ptr<PaymentMethod> pm) 
    {
        payment = move(pm);
        if (payment && payment->authorize())
        {
            cout << "[SFS Display] Payment Success!" << endl;
            return true;
        }
        cout << "[SFS Display] Unauthorized payment!" << endl;
        return false;
    }
};

// ==========================================
// 5. SYSTEM ENVIRONMENT SIMULATION
// ==========================================
int main() 
{
    InventoryItem sodaSyrup("SodaSyrupStock", 100, 10);

    cout << "===== WELCOME TO THE SODA FILLING STATION =====" << endl;
    cout << "Flat Rate Pricing Active: All drinks are $2.00" << endl;

    Order currentOrder(101);
    Transaction currentTx(5001);

    // STEP 1: FLAVOR SELECTION (Restored Prompts) 
    cout << "\n[HMI Prompt] Please select your primary drink flavor (soda1, soda2, soda3, soda4):" << endl;
    currentOrder.addFlavor("soda1");
    cout << ">> User selected: soda1" << endl;

    cout << "[HMI Prompt] Do you want to mix with other flavors? (Yes/No):" << endl;
    cout << ">> User selected: Yes" << endl;

    cout << "[HMI Prompt] Selecting additional mixing flavors from remaining options..." << endl;
    currentOrder.addFlavor("soda2");
    currentOrder.addFlavor("soda4");

    // STEP 2: PAYMENT PROCESSING 
    double owedAmount = currentTx.getTotalPrice();
    cout << "\n[HMI Display] Order Total is: $" << fixed << setprecision(2) << owedAmount << endl;

    PaymentType paymentChoice = PaymentType::Debit;
    unique_ptr<PaymentMethod> selectedPayment = nullptr;

    if (paymentChoice == PaymentType::Credit) 
    {
        string simulatedZip = "90210";
        cout << "[HMI Display] Credit Chosen. Verifying zip code entry: " << simulatedZip << endl;
        selectedPayment = make_unique<Credit>("TX_CREDIT", owedAmount, simulatedZip);
    }
    else if (paymentChoice == PaymentType::Debit) 
    {
        string simulatedPin = "1234";
        cout << "[HMI Display] Debit Chosen. Verifying PIN entry: " << simulatedPin << endl;
        selectedPayment = make_unique<Debit>("TX_DEBIT", owedAmount, simulatedPin);
    }

    // STEP 3: AUTHORIZE & DISPENSE 
    if (selectedPayment && currentTx.processPayment(move(selectedPayment)))
    {
        currentOrder.finalizeOrder(sodaSyrup);
    }

    return 0;
}
